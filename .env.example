APP_NAME=jn-engine-contributor-mcp
APP_ENV=development
SERVICE_PROFILE=engine
API_HOST=0.0.0.0
API_PORT=8788
PUBLIC_BASE_URL=https://jn-engine-gateway.example.com
MCP_PATH=/mcp
AUTH_MODE=github

JN_SNAPSHOT_PATH=/data/jn-engine
EXPECTED_REPOSITORY=alexscott2718-gif/jn-engine
EXPECTED_REF=refs/heads/master
SEARCH_ENGINE=auto

GATEWAY_SECRETS_DIR=/secrets
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET_FILE=/secrets/github_oauth_client_secret
GITHUB_COLLABORATOR_TOKEN_FILE=/secrets/github_collaborator_token
GITHUB_ACTIONS_READ_TOKEN_FILE=/secrets/github_actions_read_token
AUDIT_LOG_PATH=/audit/tool_calls.ndjson
OAUTH_JWT_SIGNING_KEY_FILE=/secrets/oauth_jwt_signing_key
OAUTH_ALLOWED_CLIENT_REDIRECT_URIS=["http://127.0.0.1:*","http://localhost:*"]
GITHUB_COLLAB_CACHE_TTL_SECONDS=300
GITHUB_COLLAB_NEGATIVE_TTL_SECONDS=60

MCP_ENROLLMENT_SECRET_FILE=
# Set true only on the authenticated engine profile to enable the audited
# claim_task, release_task, and PR-only open_pr tools. open_pr requires the
# dedicated pull-request credential below; claims never use that credential.
ENABLE_WRITE_ACTIONS=false
#GITHUB_PR_WRITE_TOKEN_FILE=/secrets/github_pr_write_token
ENABLE_SHELL_ACTIONS=false
LOG_LEVEL=INFO

# Compose-only host settings. These do not redirect application repository identity.
JN_SNAPSHOT_HOST_PATH=
GATEWAY_SECRETS_HOST_PATH=
GATEWAY_AUDIT_HOST_PATH=
CLOUDFLARED_IMAGE=
